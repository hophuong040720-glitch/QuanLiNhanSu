@{
    ViewData["Title"] = "Trang chủ Quản trị";
}

<div class="text-center mt-4 mb-5">
    <h1 class="display-5 fw-bold text-gradient-gold">HỆ THỐNG QUẢN TRỊ NHÂN SỰ TOÀN DIỆN</h1>
    <p class="lead text-muted">Công ty Cổ phần Thương mại và Dịch vụ Công nghệ HT</p>
</div>

@if (User.Identity!.IsAuthenticated)
{
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card luxury-card border-0 shadow-lg rounded-4 bg-light p-4 h-100 d-flex flex-row align-items-center">
                <div class="me-4">
                    <i class="bi bi-people-fill text-gold" style="font-size: 4rem;"></i>
                </div>
                <div>
                    <h5 class="text-dark mb-1">Tổng Nhân Sự</h5>
                    <h1 class="display-4 fw-bold text-dark mb-0">@ViewBag.TotalEmployees</h1>
                    <p class="text-muted small mb-0">Nhân sự đang hoạt động</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card luxury-card border-0 shadow-lg rounded-4 bg-light p-4 h-100 d-flex flex-row align-items-center">
                <div class="me-4">
                    <i class="bi bi-wallet2 text-success" style="font-size: 4rem;"></i>
                </div>
                <div>
                    <h5 class="text-dark mb-1">Tổng Quỹ Lương Cơ Bản</h5>
                    <h1 class="display-5 fw-bold text-success mb-0">@Convert.ToDecimal(ViewBag.TotalSalary).ToString("N0") <span class="fs-4">VNĐ</span></h1>
                    <p class="text-muted small mb-0">Ngân sách chi trả hằng tháng</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-5">
            <div class="card luxury-card border-0 shadow-lg rounded-4 p-4 h-100">
                <h6 class="fw-bold text-center text-muted mb-4">CƠ CẤU NHÂN SỰ THEO PHÒNG BAN</h6>
                <canvas id="employeeCountChart"></canvas>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card luxury-card border-0 shadow-lg rounded-4 p-4 h-100">
                <h6 class="fw-bold text-center text-muted mb-4">PHÂN BỔ QUỸ LƯƠNG THEO PHÒNG BAN</h6>
                <canvas id="salaryFundChart"></canvas>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Nhận dữ liệu từ Controller
        const labels = @Html.Raw(Json.Serialize(ViewBag.Labels));
        const countData = @Html.Raw(Json.Serialize(ViewBag.Counts));
        const salaryData = @Html.Raw(Json.Serialize(ViewBag.Salaries));

        // Bảng màu chung cho biểu đồ
        const bgColors = ['#d4af37', '#198754', '#0d6efd', '#dc3545', '#6f42c1', '#fd7e14'];

        // 1. Vẽ biểu đồ Cơ cấu nhân sự (Doughnut Chart)
        const ctxCount = document.getElementById('employeeCountChart').getContext('2d');
        new Chart(ctxCount, {
        type: 'doughnut',
        data: {
        labels: labels,
        datasets: [{
        data: countData,
        backgroundColor: bgColors,
        borderWidth: 2,
        borderColor: '#ffffff'
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: { position: 'bottom' }
        }
        }
        });

        // 2. Vẽ biểu đồ Quỹ lương (Bar Chart)
        const ctxSalary = document.getElementById('salaryFundChart').getContext('2d');
        new Chart(ctxSalary, {
        type: 'bar',
        data: {
        labels: labels,
        datasets: [{
        label: 'Quỹ lương (VNĐ)',
        data: salaryData,
        backgroundColor: bgColors,
        borderRadius: 5
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: { display: false },
        tooltip: {
        callbacks: {
        label: function(context) {
        let value = context.raw;
        return value.toLocaleString('vi-VN') + ' VNĐ';
        }
        }
        }
        },
        scales: {
        y: {
        beginAtZero: true,
        ticks: {
        callback: function(value) {
        return value.toLocaleString('vi-VN');
        }
        }
        }
        }
        }
        });
    </script>
}
else
{
    <div class="alert alert-warning text-center rounded-4 shadow-sm py-5 mt-5">
        <i class="bi bi-shield-lock-fill text-warning d-block mb-3" style="font-size: 4rem;"></i>
        <h4 class="fw-bold">Vùng Dữ Liệu Nội Bộ</h4>
        <p>Vui lòng <a asp-controller="Account" asp-action="Login" class="fw-bold text-decoration-none">Đăng nhập</a> để truy cập vào Dashboard quản trị trung tâm.</p>
    </div>
}