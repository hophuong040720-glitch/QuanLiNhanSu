@model QuanLiNhanSu.Models.Employee
@{
    ViewData["Title"] = "Thêm Nhân viên";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-lg-8">
        <div class="card luxury-card border-0 shadow-lg overflow-hidden rounded-4">
            
            <div class="p-4 bg-light border-bottom d-flex align-items-center gap-3">
                <div class="rounded-circle bg-gold p-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 55px; height: 55px;">
                    <i class="bi bi-person-plus-fill text-dark fs-3"></i>
                </div>
                <div>
                    <h4 class="fw-bold text-gradient-gold m-0">THÊM MỚI NHÂN SỰ</h4>
                    <p class="text-muted small m-0">Khởi tạo hồ sơ định danh cho cán bộ nhân viên mới</p>
                </div>
            </div>

            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" enctype="multipart/form-data" method="post">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">MÃ NHÂN VIÊN</label>
                            <input asp-for="MaNV" class="form-control luxury-input" placeholder="Ví dụ: NV006..." required />
                            <span asp-validation-for="MaNV" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">HỌ VÀ TÊN</label>
                            <input asp-for="HoTen" class="form-control luxury-input" placeholder="Nhập tên đầy đủ..." required />
                            <span asp-validation-for="HoTen" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">PHÒNG BAN CHUYÊN MÔN</label>
                            <select asp-for="PhongBan" class="form-select luxury-input" required>
                                <option value="">-- Lựa chọn phòng ban --</option>
                                <option value="IT">Kỹ thuật (IT)</option>
                                <option value="Kế toán">Kế toán</option>
                                <option value="Nhân sự">Nhân sự</option>
                                <option value="Kinh doanh">Kinh doanh</option>
                            </select>
                        </div>

                        @* ĐÃ CẬP NHẬT: THAY THẾ CHỨC VỤ THÀNH DROPDOWN CHUẨN DOANH NGHIỆP *@
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">CHỨC VỤ ĐẢM NHIỆM</label>
                            <select asp-for="ChucVu" class="form-select luxury-input" required>
                                <option value="">-- Lựa chọn chức vụ --</option>
                                <optgroup label="Ban Giám Đốc">
                                    <option value="Giám đốc (CEO)">Giám đốc (CEO)</option>
                                    <option value="Phó Giám đốc">Phó Giám đốc</option>
                                </optgroup>
                                <optgroup label="Cấp Quản Lý (Trưởng/Phó Bộ Phận)">
                                    <option value="Trưởng phòng">Trưởng phòng</option>
                                    <option value="Phó phòng">Phó phòng</option>
                                    <option value="Kế toán trưởng">Kế toán trưởng</option>
                                    <optgroup label="Cấp Nhân Viên Thực Thi">
                                        <option value="Chuyên viên chính">Chuyên viên chính</option>
                                        <option value="Chuyên viên">Chuyên viên</option>
                                        <option value="Nhân viên">Nhân viên</option>
                                        <option value="Thực tập sinh">Thực tập sinh</option>
                                    </optgroup>
                                </select>
                                <span asp-validation-for="ChucVu" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">MỨC LƯƠNG KHỞI ĐIỂM (VNĐ)</label>
                                <div class="input-group shadow-sm rounded-3">
                                    <span class="input-group-text bg-light text-gold-dark fw-bold border-end-0">₫</span>
                                    <input asp-for="Luong" type="number" class="form-control luxury-input border-start-0" placeholder="15000000" required />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">TẢI LÊN ẢNH AVATAR</label>
                                <input type="file" name="avatarFile" class="form-control luxury-input bg-white shadow-sm" accept="image/*" />
                                <span class="text-muted small mt-1 d-block" style="font-size: 0.75rem;">Có thể bỏ qua và bổ sung sau.</span>
                            </div>
                        </div>

                        <hr class="my-4 border-secondary opacity-25" />

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold rounded-3">Hủy</a>
                            <button type="submit" class="btn btn-luxury px-5 fw-bold rounded-3 shadow-sm">
                                <i class="bi bi-person-check-fill me-1"></i> Khởi Tạo Hồ Sơ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }