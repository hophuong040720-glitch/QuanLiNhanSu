@model QuanLiNhanSu.Models.Employee
@{
    ViewData["Title"] = "Xác nhận Xóa Nhân Viên";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-lg-7">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="p-4 bg-danger text-white d-flex align-items-center gap-3">
                <div class="rounded-circle bg-white bg-opacity-25 p-3 d-flex align-items-center justify-content-center" style="width:55px;height:55px;">
                    <i class="bi bi-person-x-fill fs-3"></i>
                </div>
                <div>
                    <h4 class="fw-bold m-0">XÁC NHẬN XÓA NHÂN VIÊN</h4>
                    <p class="m-0 opacity-75 small">Hành động này không thể hoàn tác. Tài khoản đăng nhập sẽ bị xóa theo.</p>
                </div>
            </div>

            <div class="card-body p-4 p-md-5">
                <div class="alert alert-danger border-0 rounded-3 mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Bạn có chắc chắn muốn <strong>xóa vĩnh viễn</strong> nhân viên sau khỏi hệ thống?
                </div>

                <div class="bg-light rounded-3 p-4 mb-4 border">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl" class="rounded-circle border border-3 border-danger shadow-sm" style="width:70px;height:70px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width:70px;height:70px;font-size:2rem;">
                                @Model.HoTen.Substring(0, 1).ToUpper()
                            </div>
                        }
                        <div>
                            <h5 class="fw-bold text-dark mb-1">@Model.HoTen</h5>
                            <span class="badge bg-dark px-3 py-1">@Model.MaNV</span>
                        </div>
                    </div>
                    <table class="table table-borderless mb-0 small">
                        <tr>
                            <td class="text-muted fw-semibold" style="width:130px;"><i class="bi bi-diagram-3-fill me-1"></i> Phòng Ban</td>
                            <td><span class="badge bg-gold text-dark px-2">@Model.TenPhongBan</span></td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold"><i class="bi bi-briefcase-fill me-1"></i> Chức Vụ</td>
                            <td class="fw-semibold">@Model.TenChucVu</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold"><i class="bi bi-cash-stack me-1"></i> Mức Lương</td>
                            <td class="fw-bold text-success">@Model.Luong.ToString("N0") VNĐ</td>
                        </tr>
                    </table>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold rounded-3">
                        <i class="bi bi-arrow-left me-1"></i> Hủy bỏ
                    </a>
                    <form asp-action="Delete" method="post" class="d-inline">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger px-5 fw-bold rounded-3 shadow-sm">
                            <i class="bi bi-trash3-fill me-1"></i> Xác nhận Xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
