<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Nhân Sự</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuanLiNhanSu.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="luxury-theme">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light luxury-navbar border-bottom box-shadow mb-4">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-dark d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-award-fill text-gold me-2" style="font-size: 1.4rem;"></i>
                    <span>HR SYSTEM</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 mb-2 mb-sm-0">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách</a>
                        </li>

                        @if (User.Identity!.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold text-gold-dark" asp-area="" asp-controller="Employees" asp-action="Index">
                                    <i class="bi bi-people-fill me-1"></i> Quản lý Nhân viên
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center me-3 mb-2 mb-sm-0">
                                <span class="text-dark fw-medium small">
                                    Xin chào, <b class="text-gold-dark">@User.Identity.Name</b>
                                    <span class="badge bg-gold text-dark ms-1">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm px-3 rounded-pill fw-semibold" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2 mb-2 mb-sm-0">
                                <a class="btn btn-outline-gold btn-sm px-4 py-2 rounded-pill fw-bold shadow-sm" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus-fill me-1"></i> Đăng ký
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-luxury btn-sm px-4 py-2 rounded-pill fw-bold shadow-sm" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-center py-4 text-muted small bg-transparent">
        <div class="container">
            &copy; 2026 - Hệ thống Quản lý Nhân sự - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-gold-dark fw-semibold">Bảo mật</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>