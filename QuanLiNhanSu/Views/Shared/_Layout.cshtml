<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Nhân Sự</title>
    
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuanLiNhanSu.styles.css" asp-append-version="true" />
    
    <!-- Tránh FOUC (Flash of Unstyled Content) cho Dark Mode -->
    <script>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
        }
    </script>
</head>
<body>
    <div class="wrapper">
        <!-- SIDEBAR -->
        <nav id="sidebar">
            <div class="sidebar-header d-flex align-items-center justify-content-center">
                <i class="bi bi-award-fill text-gold fs-2"></i>
                <h4 class="m-0 ms-2 fw-bold text-gradient-gold">HR SYSTEM</h4>
            </div>

            <ul class="sidebar-menu">
                <li class="small text-muted fw-bold mb-2 mt-2 px-3 text-uppercase" style="font-size: 0.75rem;">Tổng Quan</li>
                <li>
                    <a asp-controller="Home" asp-action="Index">
                        <i class="bi bi-grid-1x2-fill"></i> <span>Dashboard</span>
                    </a>
                </li>
                
                @if (User.Identity!.IsAuthenticated)
                {
                    <li class="small text-muted fw-bold mb-2 mt-4 px-3 text-uppercase" style="font-size: 0.75rem;">Quản Lý Nhân Sự</li>
                    <li>
                        <a asp-controller="Employees" asp-action="Index">
                            <i class="bi bi-people-fill"></i> <span>Hồ sơ nhân viên</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="HopDong" asp-action="Index">
                            <i class="bi bi-file-earmark-text-fill"></i> <span>Hợp đồng lao động</span>
                        </a>
                    </li>
                    
                    <li class="small text-muted fw-bold mb-2 mt-4 px-3 text-uppercase" style="font-size: 0.75rem;">Thời Gian & Tiền Lương</li>
                    <li>
                        <a asp-controller="ChamCong" asp-action="Index">
                            <i class="bi bi-fingerprint"></i> <span>Chấm công</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="NghiPhep" asp-action="Index">
                            <i class="bi bi-calendar-event"></i> <span>Nghỉ phép</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="UngLuong" asp-action="Index">
                            <i class="bi bi-cash-coin"></i> <span>Ứng lương</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="KhenThuongKyLuat" asp-action="Index">
                            <i class="bi bi-award-fill"></i> <span>Khen thưởng/Kỷ luật</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="BangLuong" asp-action="Index">
                            <i class="bi bi-wallet2"></i> <span>Bảng lương</span>
                        </a>
                    </li>

                    <li class="small text-muted fw-bold mb-2 mt-4 px-3 text-uppercase" style="font-size: 0.75rem;">Khác</li>
                    <li>
                        <a asp-controller="PhanCong" asp-action="Index">
                            <i class="bi bi-card-checklist"></i> <span>Công việc</span>
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li>
                            <a asp-controller="SystemLog" asp-action="Index">
                                <i class="bi bi-shield-lock-fill"></i> <span>Nhật ký hệ thống</span>
                            </a>
                        </li>
                    }
                }
            </ul>

            <!-- Footer Sidebar (User Info & Theme Toggle) -->
            <div class="sidebar-footer">
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="user-info d-flex align-items-center mb-3">
                        <div class="bg-gold-light rounded-circle p-2 me-2 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <i class="bi bi-person-fill text-gold fs-5"></i>
                        </div>
                        <div style="line-height: 1.2;">
                            <div class="fw-bold fs-6">@User.Identity.Name</div>
                            <small class="text-muted">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</small>
                        </div>
                    </div>
                }
                
                <div class="d-flex justify-content-between">
                    <button class="btn btn-sm btn-light border shadow-sm w-100" id="theme-toggle" title="Chuyển chế độ Sáng/Tối">
                        <i class="bi bi-moon-stars-fill text-dark"></i>
                    </button>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-danger ms-2 shadow-sm" title="Đăng xuất">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    }
                </div>
            </div>
        </nav>

        <!-- MAIN CONTENT AREA -->
        <div id="content">
            <!-- TOP NAVBAR -->
            <nav class="navbar top-navbar d-flex justify-content-between align-items-center sticky-top">
                <div class="d-flex align-items-center">
                    <button type="button" id="sidebar-toggle" class="btn btn-light shadow-sm me-3 border">
                        <i class="bi bi-list fs-5"></i>
                    </button>
                    <nav aria-label="breadcrumb" class="d-none d-md-block">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item text-muted"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Home</a></li>
                            <li class="breadcrumb-item active fw-bold text-dark" aria-current="page">@ViewData["Title"]</li>
                        </ol>
                    </nav>
                </div>
                
                <div>
                    @if (!User.Identity.IsAuthenticated)
                    {
                        <a class="btn btn-outline-gold rounded-pill px-4 me-2 fw-bold" asp-controller="Account" asp-action="Register">Đăng ký</a>
                        <a class="btn btn-luxury rounded-pill px-4 fw-bold shadow-sm" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    }
                    else
                    {
                        <a asp-controller="Employees" asp-action="MyProfile" class="btn btn-light rounded-pill px-3 shadow-sm border fw-bold text-primary">
                            <i class="bi bi-person-badge me-1"></i> Hồ sơ của tôi
                        </a>
                    }
                </div>
            </nav>

            <!-- RENDER BODY -->
            <div class="container-fluid p-4 p-md-5">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
            
            <!-- FOOTER -->
            <footer class="text-center py-4 text-muted small mt-auto">
                <div class="container-fluid border-top pt-3">
                    &copy; 2026 - HT Technology HR System - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-gold-dark fw-bold">Chính sách bảo mật</a>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- SWEETALERT2 NOTIFICATIONS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success', title: 'Thành công', text: @Html.Raw(Json.Serialize(TempData["Success"])),
                toast: true, position: 'top-end', showConfirmButton: false, timer: 3000, timerProgressBar: true
            });
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'warning', title: 'Cảnh báo', text: @Html.Raw(Json.Serialize(TempData["Error"])),
                toast: true, position: 'top-end', showConfirmButton: false, timer: 4000, timerProgressBar: true
            });
        </script>
    }
</body>
</html>