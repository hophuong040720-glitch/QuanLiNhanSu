@using QuanLiNhanSu.Models
@inject AppDbContext _context
@{
    var pendingLeaves = 0;
    var pendingAdvances = 0;
    var newTasks = 0;

    if (User.IsInRole("Admin") || User.IsInRole("Nhân sự"))
    {
        pendingLeaves = _context.PhieuNghiPheps.Count(p => p.TrangThai == "Chờ duyệt");
        pendingAdvances = _context.UngLuongs.Count(p => p.TrangThai == "Chờ duyệt");
    }
    else if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var currentUser = User.Identity.Name;
        newTasks = _context.PhanCongs.Count(p => p.MaNV == currentUser && p.TrangThai == "Mới giao");
    }

    var totalNoti = (pendingLeaves > 0 ? 1 : 0) + (pendingAdvances > 0 ? 1 : 0) + (newTasks > 0 ? 1 : 0);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Nhân Sự</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuanLiNhanSu.styles.css" asp-append-version="true" />
</head>
<body class="top-nav-layout">

    <!-- ===== TOP NAVBAR STICKY ===== -->
    <nav class="navbar navbar-expand-lg fixed-top shadow-sm top-navbar" style="background: var(--bg-card); backdrop-filter: blur(10px);">
        <div class="container-fluid px-3 px-md-4">
            
            <!-- Logo Brand -->
            <a class="navbar-brand d-flex align-items-center gap-2 fw-bold text-gradient-gold me-4" asp-controller="Home" asp-action="Index">
                <div class="brand-icon-wrapper rounded-3 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark)); color: white;">
                    <i class="bi bi-buildings-fill fs-5"></i>
                </div>
                <span class="fs-4 ms-1" style="font-family: 'Outfit', sans-serif;">HRLuxury</span>
            </a>

            <!-- Nút Toggle Mobile -->
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#topNavbarCollapse" aria-controls="topNavbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list fs-2 text-dark"></i>
            </button>

            <!-- Menu Chính -->
            <div class="collapse navbar-collapse" id="topNavbarCollapse">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1 fw-semibold">
                    <li class="nav-item">
                        <a class="nav-link top-nav-link px-3 py-2 rounded-3" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-fill me-1"></i> Tổng Quan
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link top-nav-link dropdown-toggle px-3 py-2 rounded-3" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-people-fill me-1"></i> Nhân Sự
                        </a>
                        <ul class="dropdown-menu top-dropdown-menu shadow-sm border-0 mt-2">
                            <li><a class="dropdown-item py-2" asp-controller="Employees" asp-action="Index">Danh sách Nhân viên</a></li>
                            <li><a class="dropdown-item py-2" asp-controller="HopDong" asp-action="Index">Quản lý Hợp đồng</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link top-nav-link dropdown-toggle px-3 py-2 rounded-3" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-fingerprint me-1"></i> Chấm Công
                        </a>
                        <ul class="dropdown-menu top-dropdown-menu shadow-sm border-0 mt-2">
                            <li><a class="dropdown-item py-2" asp-controller="ChamCong" asp-action="Index">Check-in Face ID</a></li>
                            <li><a class="dropdown-item py-2" asp-controller="NghiPhep" asp-action="Index">Đơn Nghỉ Phép</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link top-nav-link dropdown-toggle px-3 py-2 rounded-3" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-wallet2 me-1"></i> Tài Chính
                        </a>
                        <ul class="dropdown-menu top-dropdown-menu shadow-sm border-0 mt-2">
                            <li><a class="dropdown-item py-2" asp-controller="BangLuong" asp-action="Index">Bảng Lương</a></li>
                            <li><a class="dropdown-item py-2" asp-controller="UngLuong" asp-action="Index">Tạm Ứng</a></li>
                            <li><a class="dropdown-item py-2" asp-controller="KhenThuongKyLuat" asp-action="Index">Khen Thưởng & Kỷ Luật</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link top-nav-link dropdown-toggle px-3 py-2 rounded-3" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-clipboard2-data-fill me-1"></i> Báo Cáo
                        </a>
                        <ul class="dropdown-menu top-dropdown-menu shadow-sm border-0 mt-2">
                            <li><a class="dropdown-item py-2" asp-controller="PhanCong" asp-action="Index">Phân Công</a></li>
                            <li><a class="dropdown-item py-2" asp-controller="WorkReports" asp-action="Index">Báo Cáo Công Việc</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="dropdown-item py-2" asp-controller="SystemLog" asp-action="Index">Nhật Ký Hệ Thống</a></li>
                            }
                        </ul>
                    </li>
                </ul>

                @if (User.Identity!.IsAuthenticated)
                {
                    <!-- GÓC PHẢI: Thông báo + User Profile (Đã xóa nút Dark Mode) -->
                    <div class="d-flex align-items-center gap-2 ms-auto">

                        <!-- Chuông thông báo -->
                        <div class="dropdown">
                            <button class="btn btn-sm top-action-btn position-relative" title="Thông báo" data-bs-toggle="dropdown" id="bellDropdown" aria-expanded="false">
                                <i class="bi bi-bell-fill"></i>
                                @if (totalNoti > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem;">@totalNoti</span>
                                }
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end top-dropdown-menu shadow-lg border-0" style="min-width:280px;">
                                <li class="px-3 py-2 fw-bold border-bottom">Thông báo mới</li>
                                
                                @if (totalNoti == 0)
                                {
                                    <li><span class="dropdown-item py-3 text-muted text-center"><small>Bạn không có thông báo mới nào.</small></span></li>
                                }
                                
                                @if (User.IsInRole("Admin") || User.IsInRole("Nhân sự"))
                                {
                                    @if (pendingLeaves > 0)
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="NghiPhep" asp-action="Index"><i class="bi bi-calendar-x text-warning me-2"></i><small>Có <strong>@pendingLeaves</strong> đơn xin nghỉ phép đang chờ duyệt.</small></a></li>
                                    }
                                    @if (pendingAdvances > 0)
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="UngLuong" asp-action="Index"><i class="bi bi-cash-stack text-warning me-2"></i><small>Có <strong>@pendingAdvances</strong> đơn ứng lương đang chờ duyệt.</small></a></li>
                                    }
                                }
                                else
                                {
                                    @if (newTasks > 0)
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="PhanCong" asp-action="Index"><i class="bi bi-card-checklist text-primary me-2"></i><small>Bạn có <strong>@newTasks</strong> công việc mới được giao.</small></a></li>
                                    }
                                }
                            </ul>
                        </div>

                        <!-- User Profile Dropdown -->
                        <div class="dropdown">
                            <button class="btn user-profile-btn dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown" id="userDropdown" aria-expanded="false">
                                <div class="user-avatar-top">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <div class="d-none d-md-block text-start lh-1">
                                    <div class="fw-bold" style="font-size:0.85rem;">@User.Identity.Name</div>
                                    <div class="text-muted" style="font-size:0.72rem;">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</div>
                                </div>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end top-dropdown-menu shadow-lg border-0" style="min-width:200px;">
                                <li>
                                    <a class="dropdown-item top-dropdown-item" asp-controller="Employees" asp-action="MyProfile">
                                        <i class="bi bi-person-badge me-2 text-primary"></i> Hồ sơ của tôi
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider my-1"></li>
                                <li>
                                    <a class="dropdown-item top-dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                }
                else
                {
                    <div class="d-flex gap-2 ms-auto">
                        <a class="btn btn-outline-gold rounded-pill px-4 fw-bold" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    </div>
                }
            </div>
        </div>
    </nav>

    <!-- ===== NỘI DUNG CHÍNH ===== -->
    <div class="top-nav-content">
        <div class="container-fluid p-4 p-md-5">
            <main role="main">
                @RenderBody()
            </main>
        </div>

        <!-- FOOTER -->
        <footer class="text-center py-4 text-muted small mt-auto">
            <div class="container-fluid border-top pt-3">
                &copy; 2026 - HT Technology HR System - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-gold-dark fw-bold">Chính sách bảo mật</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- SWEETALERT2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({ icon: 'success', title: 'Thành công', text: @Html.Raw(Json.Serialize(TempData["Success"])), toast: true, position: 'top-end', showConfirmButton: false, timer: 3000, timerProgressBar: true });
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({ icon: 'warning', title: 'Cảnh báo', text: @Html.Raw(Json.Serialize(TempData["Error"])), toast: true, position: 'top-end', showConfirmButton: false, timer: 4000, timerProgressBar: true });
        </script>
    }

    <!-- Menu Script -->
    <script>
        // ACTIVE MENU HIGHLIGHT
        (function () {
            var currentPath = window.location.pathname;
            document.querySelectorAll('.top-nav-link').forEach(function (link) {
                try {
                    var href = link.getAttribute('href');
                    if (!href || href === '#') return;
                    
                    var linkPath = new URL(link.href, window.location.origin).pathname;
                    if (linkPath !== '/' && currentPath.startsWith(linkPath)) {
                        link.classList.add('active');
                    } else if (linkPath === '/' && currentPath === '/') {
                        link.classList.add('active');
                    }
                } catch (e) { }
            });
        })();
    </script>
</body>
</html>