@model IEnumerable<QuanLiNhanSu.Models.SystemLog>
@{
    ViewData["Title"] = "Nhật ký Hệ thống";
    Layout = "_Layout";
}

<div class="card luxury-card border-0 shadow-lg my-4 rounded-4">
    <div class="card-body p-4 p-md-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold text-gradient-gold m-0"><i class="bi bi-shield-lock-fill me-2"></i>NHẬT KÝ HỆ THỐNG</h3>
                <p class="text-muted small m-0">Audit Trail - Theo dõi toàn bộ hoạt động trong hệ thống theo thời gian thực</p>
            </div>
            <span class="badge bg-danger fs-6 px-3 py-2 shadow-sm">
                <i class="bi bi-eye-fill me-1"></i> Chỉ Admin
            </span>
        </div>

        <div class="table-responsive overflow-hidden rounded-3 border">
            <table class="table table-hover align-middle mb-0 bg-white">
                <thead style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%);">
                    <tr class="text-white small fw-semibold">
                        <th class="ps-3 py-3" style="width: 160px;"><i class="bi bi-clock me-1"></i> THỜI GIAN</th>
                        <th style="width: 140px;"><i class="bi bi-person-fill me-1"></i> TÀI KHOẢN</th>
                        <th style="width: 160px;"><i class="bi bi-lightning-fill me-1"></i> HÀNH ĐỘNG</th>
                        <th style="width: 130px;"><i class="bi bi-database-fill me-1"></i> ĐỐI TƯỢNG</th>
                        <th><i class="bi bi-card-text me-1"></i> CHI TIẾT</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-journal-x fs-2 d-block mb-2 opacity-50"></i>
                                Chưa có nhật ký hệ thống nào được ghi nhận.
                            </td>
                        </tr>
                    }
                    @foreach (var log in Model)
                    {
                        // Xác định màu badge dựa trên loại hành động
                        var badgeClass = log.Action switch {
                            var a when a.Contains("Thêm") || a.Contains("Tạo") || a.Contains("Đăng ký") => "bg-success",
                            var a when a.Contains("Xóa") => "bg-danger",
                            var a when a.Contains("Sửa") || a.Contains("Cập nhật") => "bg-warning text-dark",
                            var a when a.Contains("Đăng nhập") && !a.Contains("thất bại") => "bg-primary",
                            var a when a.Contains("thất bại") || a.Contains("Từ chối") => "bg-danger",
                            var a when a.Contains("Đăng xuất") => "bg-secondary",
                            var a when a.Contains("Duyệt") => "bg-success",
                            var a when a.Contains("Chốt") => "bg-info text-dark",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td class="ps-3 text-muted small">
                                <span class="d-block fw-semibold text-dark">@log.Timestamp.ToString("dd/MM/yyyy")</span>
                                <span class="text-primary small">@log.Timestamp.ToString("HH:mm:ss")</span>
                            </td>
                            <td>
                                <span class="fw-bold text-dark">@log.Username</span>
                            </td>
                            <td>
                                <span class="badge @badgeClass px-2 py-1 small">@log.Action</span>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border px-2 py-1 small">@log.Target</span>
                            </td>
                            <td class="text-muted small" style="max-width: 400px;">
                                <span class="text-truncate d-inline-block" style="max-width: 380px;" title="@log.Details">
                                    @log.Details
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3 text-muted small text-end">
            Tổng cộng: <strong>@Model.Count()</strong> bản ghi được tìm thấy.
        </div>
    </div>
</div>