@model QuanLiNhanSu.Models.RegisterViewModel
@{
    Layout = "_Layout"; ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-lg">
            <div class="card-header bg-success text-white text-center py-3">
                <h3 class="font-weight-light my-1">ĐĂNG KÝ TÀI KHOẢN</h3>
            </div>
            <div class="card-body p-4">
                <form asp-action="Register" method="post">
                    <div class="form-floating mb-3">
                        <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập" required />
                        <label>Tên đăng nhập</label>
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" required />
                        <label>Địa chỉ Email</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu" required />
                        <label>Mật khẩu</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Xác nhận mật khẩu" required />
                        <label>Xác nhận mật khẩu</label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2">@ViewBag.Error</div>
                    }

                    <button type="submit" class="btn btn-success w-100 mt-2">Tạo tài khoản</button>
                </form>
            </div>
            <div class="card-footer text-center py-3">
                <div class="small"><a asp-action="Login">Đã có tài khoản? Đăng nhập ngay</a></div>
            </div>
        </div>
    </div>
</div>