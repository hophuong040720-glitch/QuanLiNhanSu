@model QuanLiNhanSu.Models.ForgotPasswordViewModel
@{
    Layout = "_Layout"; ViewData["Title"] = "Khôi phục mật khẩu";
}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-lg">
            <div class="card-header bg-warning text-dark text-center py-3">
                <h3 class="font-weight-light my-1">KHÔI PHỤC MẬT KHẨU</h3>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-success text-center">
                        @ViewBag.Success <br /><br />
                        <a asp-action="Login" class="btn btn-primary btn-sm">Về trang đăng nhập</a>
                    </div>
                }
                else
                {
                    <form asp-action="ForgotPassword" method="post">
                        <p class="text-muted small mb-3">Vui lòng xác nhận đúng Tên đăng nhập và Email của bạn để đặt lại mật khẩu mới.</p>
                        <div class="form-floating mb-3">
                            <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập" required />
                            <label>Tên đăng nhập</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="Email" required />
                            <label>Email đã đăng ký</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="Mật khẩu mới" required />
                            <label>Mật khẩu mới</label>
                        </div>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger py-2">@ViewBag.Error</div>
                        }

                        <button type="submit" class="btn btn-warning w-100 mt-2 fw-bold">Xác nhận đổi mật khẩu</button>
                    </form>
                }
            </div>
            <div class="card-footer text-center py-3">
                <div class="small"><a asp-action="Login">Quay lại đăng nhập</a></div>
            </div>
        </div>
    </div>
</div>