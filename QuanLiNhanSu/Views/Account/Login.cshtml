@{
    Layout = "_Layout"; // Sử dụng khung chung của web
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="row justify-content-center" style="margin-top: 100px;">
    <div class="col-md-4">
        <div class="card shadow-lg border-0 rounded-lg">
            <div class="card-header bg-primary text-white text-center py-3">
                <h3 class="font-weight-light my-1">ĐĂNG NHẬP</h3>
            </div>
            <div class="card-body p-4">
                <form asp-controller="Account" asp-action="Login" method="post">
                    <div class="form-floating mb-3">
                        <input class="form-control" name="username" id="inputUser" type="text" placeholder="Tên đăng nhập" required />
                        <label for="inputUser">Tên đăng nhập</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input class="form-control" name="password" id="inputPassword" type="password" placeholder="Mật khẩu" required />
                        <label for="inputPassword">Mật khẩu</label>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                        </div>
                    }

                    <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                        <div class="form-check">
                            <input class="form-check-input" id="rememberPass" type="checkbox" value="" />
                            <label class="form-check-label" for="rememberPass">Ghi nhớ mật khẩu</label>
                        </div>
                        <button type="submit" class="btn btn-primary px-4">Đăng nhập</button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center py-3">
                <div class="small"><a href="#">Quên mật khẩu? Liên hệ Admin</a></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        /* Thêm một chút CSS để trang đẹp hơn */
        body {
            background-color: #f8f9fa;
        }
        .card {
            transition: all 0.3s ease;
        }
        .card:hover {
            transform: translateY(-5px);
        }
    </style>
}