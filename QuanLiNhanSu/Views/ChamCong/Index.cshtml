@model IEnumerable<QuanLiNhanSu.Models.ChamCong>
@{
    ViewData["Title"] = "Chấm công sinh trắc học";
    Layout = "_Layout";
    bool isAdminOrAccountant = User.IsInRole("Admin") || User.IsInRole("KeToan");
}

<style>
    /* CSS cho Face ID */
    .face-scanner-container {
        position: relative;
        width: 100%;
        max-width: 320px;
        margin: 0 auto;
        border-radius: 15px;
        overflow: hidden;
        border: 3px solid #198754;
        display: none;
        background: #000;
    }
    #webcam-feed {
        width: 100%;
        height: auto;
        transform: scaleX(-1);
    }
    .scan-line {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 4px;
        background: #00ff00;
        box-shadow: 0 0 15px #00ff00, 0 0 30px #00ff00;
        animation: scan 2s linear infinite;
    }
    .face-overlay {
        position: absolute;
        top: 10%; left: 15%; width: 70%; height: 80%;
        border: 2px dashed rgba(0, 255, 0, 0.5);
        border-radius: 20%;
    }
    @@keyframes scan { 0% { top: 0%; } 50% { top: 100%; } 100% { top: 0%; } }

    /* CSS cho Fingerprint */
    @@keyframes pulse-finger {
        0% { transform: scale(1); opacity: 0.8; }
        50% { transform: scale(1.1); opacity: 1; text-shadow: 0 0 20px #198754; }
        100% { transform: scale(1); opacity: 0.8; }
    }
    .fingerprint-btn {
        font-size: 5rem;
        cursor: pointer;
        color: #d4af37;
        transition: all 0.3s ease;
    }
    .fingerprint-btn:hover {
        color: #198754;
        animation: pulse-finger 1.5s infinite;
    }
    .nav-pills .nav-link.active {
        background-color: #d4af37 !important;
        color: #000 !important;
        font-weight: bold;
    }
    .nav-pills .nav-link {
        color: #6c757d;
        font-weight: 500;
    }
</style>

<div class="row g-4 mt-2 mb-5">
    <div class="col-md-4">
        <div class="card luxury-card border-0 shadow-lg rounded-4 text-center">
            <div class="p-4 bg-light border-bottom">
                <h5 class="fw-bold text-gradient-gold m-0">TRẠM XÁC THỰC</h5>
                <p class="text-muted small m-0 mt-1">Lựa chọn phương thức định danh</p>
            </div>
            
            <div class="card-body p-4">
                <ul class="nav nav-pills nav-fill mb-4 p-1 bg-light rounded-pill border" id="pills-tab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active rounded-pill" id="pills-face-tab" data-bs-toggle="pill" data-bs-target="#pills-face" type="button" role="tab">
                            <i class="bi bi-person-bounding-box me-1"></i> Face ID
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link rounded-pill" id="pills-finger-tab" data-bs-toggle="pill" data-bs-target="#pills-finger" type="button" role="tab">
                            <i class="bi bi-fingerprint me-1"></i> Vân Tay
                        </button>
                    </li>
                </ul>

                <form id="checkInForm" asp-action="CheckIn" method="post">
                    <input type="hidden" name="ghiChu" id="hinhThucXacThuc" value="Chấm công bằng Face ID" />

                    <div class="tab-content" id="pills-tabContent">
                        <div class="tab-pane fade show active" id="pills-face" role="tabpanel" tabindex="0">
                            <div id="scanner-ui" class="face-scanner-container mb-3 shadow">
                                <video id="webcam-feed" autoplay playsinline></video>
                                <div class="face-overlay"></div>
                                <div class="scan-line"></div>
                            </div>
                            <button type="button" id="btn-start-scan" class="btn btn-dark w-100 py-3 fw-bold rounded-3 shadow mb-3" onclick="startFaceID()">
                                <i class="bi bi-camera-video-fill me-1"></i> BẬT CAMERA QUÉT
                            </button>
                        </div>

                        <div class="tab-pane fade" id="pills-finger" role="tabpanel" tabindex="0">
                            <div class="mb-4 pt-3" onclick="triggerFingerprintScan()">
                                <i class="bi bi-fingerprint fingerprint-btn d-block mx-auto"></i>
                                <span class="badge bg-secondary mt-3 px-3 py-2 rounded-pill shadow-sm">Chạm vào vân tay để giả lập</span>
                            </div>
                            <div class="alert alert-warning small border-0 text-start">
                                <i class="bi bi-info-circle-fill me-1"></i> Hệ thống đang chờ tín hiệu từ máy ZKTeco qua cổng API (Postman). Bạn cũng có thể bấm trực tiếp vào biểu tượng để giả lập quét trên Web.
                            </div>
                        </div>
                    </div>

                    <div class="text-start mt-3 border-top pt-3">
                        <label class="form-label small fw-bold text-muted">KẾT QUẢ TÍNH CÔNG</label>
                        <select name="trangThai" class="form-select luxury-input" required>
                            <option value="Đi làm">🟢 Đủ ca (Khớp sinh trắc học)</option>
                            <option value="Nửa ngày">🟡 Nửa ca (Có phép/Lý do)</option>
                        </select>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card luxury-card border-0 shadow-lg rounded-4">
            <div class="p-4 bg-light border-bottom">
                <h5 class="fw-bold text-dark m-0"><i class="bi bi-server text-gold-dark me-2"></i>DỮ LIỆU MÁY CHẤM CÔNG</h5>
            </div>
            <div class="card-body p-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle custom-luxury-table">
                        <thead class="table-light">
                            <tr>
                                @if (isAdminOrAccountant) { <th>MÃ NV</th> }
                                <th>THỜI GIAN QUÉT</th>
                                <th>PHƯƠNG THỨC</th>
                                <th>TRẠNG THÁI</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any()) {
                                <tr><td colspan="@(isAdminOrAccountant ? 4 : 3)" class="text-center py-4 text-muted">Hệ thống chưa ghi nhận dữ liệu.</td></tr>
                            }
                            @foreach (var log in Model) {
                                <tr>
                                    @if (isAdminOrAccountant) { <td class="fw-bold text-gold-dark">@log.MaNV</td> }
                                    <td>@log.NgayChamCong.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    
                                    <td>
                                        @if(log.GhiChu != null && log.GhiChu.Contains("Face ID")) {
                                            <span class="badge bg-dark"><i class="bi bi-person-bounding-box text-info me-1"></i>Face ID</span>
                                        } else {
                                            <span class="badge bg-dark"><i class="bi bi-fingerprint text-success me-1"></i>Vân tay</span>
                                        }
                                    </td>
                                    <td>
                                        @if (log.TrangThai == "Đi làm") { <span class="badge bg-success">Hợp lệ</span> }
                                        else { <span class="badge bg-warning text-dark">Nửa ca</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- SIGNALR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <!-- FACE-API.JS -->
    <script src="https://cdn.jsdelivr.net/npm/@@vladmandic/face-api/dist/face-api.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Cập nhật phương thức vào Ghi chú khi đổi Tab
        document.getElementById('pills-face-tab').addEventListener('click', function () {
            document.getElementById('hinhThucXacThuc').value = "Chấm công bằng Face ID";
        });
        document.getElementById('pills-finger-tab').addEventListener('click', function () {
            document.getElementById('hinhThucXacThuc').value = "Chấm công bằng Vân tay (Web)";
        });

        // 1. SIGNALR: Lắng nghe sự kiện quét vân tay từ API / máy vật lý
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chamconghub")
            .build();

        connection.on("ReceiveFingerprintScan", (maNV, action, message) => {
            // Chỉ hiển thị thông báo nếu mã nhân viên quét trùng với user đang đăng nhập trên màn hình này
            if (maNV === '@User.Identity!.Name') {
                Swal.fire({
                    icon: action === 'Warning' ? 'warning' : 'success',
                    title: 'Dữ liệu từ máy vân tay',
                    text: message,
                    timer: 3000,
                    showConfirmButton: false
                }).then(() => {
                    // Tự động tải lại trang để thấy dữ liệu mới
                    window.location.reload();
                });
            }
        });

        connection.start().catch(err => console.error("SignalR Connection Error: ", err.toString()));

        // 2. Kịch bản Face ID (Sử dụng face-api.js)
        async function startFaceID() {
            const btn = document.getElementById('btn-start-scan');
            const scannerUI = document.getElementById('scanner-ui');
            const video = document.getElementById('webcam-feed');

            btn.disabled = true;
            btn.innerHTML = '<i class="spinner-border spinner-border-sm me-2"></i> ĐANG TẢI AI MODEL...';

            try {
                // Tải model AI từ CDN (Dùng của justadudewhohacks)
                const MODEL_URL = 'https://cdn.jsdelivr.net/gh/justadudewhohacks/face-api.js@master/weights';
                await faceapi.nets.ssdMobilenetv1.loadFromUri(MODEL_URL);
                await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL);
                await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);

                btn.innerHTML = '<i class="spinner-border spinner-border-sm me-2"></i> ĐANG TẢI ẢNH MẪU...';
                
                // Lấy ảnh Avatar của người dùng hiện tại
                const userAvatarUrl = '@Html.Raw(ViewBag.UserAvatar)';
                if (userAvatarUrl.includes("default-avatar.png")) {
                    throw new Error("Bạn chưa có ảnh đại diện cá nhân trên hệ thống. Cần có 1 tấm ảnh chân dung rõ mặt để máy AI có thể đối chiếu với Camera!");
                }

                const img = await faceapi.fetchImage(userAvatarUrl);
                const detections = await faceapi.detectSingleFace(img).withFaceLandmarks().withFaceDescriptor();
                
                if (!detections) {
                    throw new Error("Ảnh đại diện hiện tại của bạn không rõ khuôn mặt. Vui lòng cập nhật ảnh chân dung rõ nét hơn để làm mẫu chuẩn!");
                }
                const avatarDescriptor = detections.descriptor;

                // Mở Webcam
                btn.style.display = 'none';
                scannerUI.style.display = 'block';

                const stream = await navigator.mediaDevices.getUserMedia({ video: {} });
                video.srcObject = stream;

                // Quét luồng video liên tục để tìm khuôn mặt khớp
                video.addEventListener('play', () => {
                    const canvas = faceapi.createCanvasFromMedia(video);
                    scannerUI.append(canvas);
                    const displaySize = { width: video.width || 320, height: video.height || 240 };
                    faceapi.matchDimensions(canvas, displaySize);

                    const interval = setInterval(async () => {
                        const videoDetections = await faceapi.detectSingleFace(video).withFaceLandmarks().withFaceDescriptor();
                        
                        if (videoDetections) {
                            // Tính khoảng cách giữa khuôn mặt trên cam và khuôn mặt mẫu (càng nhỏ càng giống)
                            const distance = faceapi.euclideanDistance(avatarDescriptor, videoDetections.descriptor);
                            console.log("Độ sai lệch: " + distance);
                            
                            // Ngưỡng 0.55 là độ chính xác an toàn
                            if (distance < 0.55) {
                                clearInterval(interval);
                                stream.getTracks().forEach(track => track.stop());
                                
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Face ID Hợp lệ!',
                                    text: 'Đã xác thực chính xác danh tính của bạn.',
                                    timer: 1500,
                                    showConfirmButton: false
                                }).then(() => {
                                    document.getElementById('checkInForm').submit();
                                });
                            }
                        }
                    }, 500); // Quét mỗi 0.5 giây
                });

            } catch (err) {
                Swal.fire('Cảnh báo từ hệ thống', err.message || 'Vui lòng cấp quyền Webcam và thử lại!', 'warning');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-camera-video-fill me-1"></i> BẬT CAMERA QUÉT';
                scannerUI.style.display = 'none';
            }
        }

        // 3. Kịch bản Vân Tay Giả Lập trên UI (Dự phòng)
        function triggerFingerprintScan() {
            Swal.fire({
                title: 'Đang đọc vân tay...',
                html: `<i class="bi bi-fingerprint text-success" style="font-size: 5rem; animation: pulse-finger 1s infinite;"></i>`,
                showConfirmButton: false,
                timer: 2000,
                didOpen: () => { Swal.showLoading(); }
            }).then((result) => {
                if (result.dismiss === Swal.DismissReason.timer) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Vân tay hợp lệ!',
                        timer: 1000,
                        showConfirmButton: false
                    }).then(() => {
                        document.getElementById('checkInForm').submit();
                    });
                }
            });
        }
    </script>
}