@model QuanLiNhanSu.Models.WorkReport
<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card luxury-card p-4 shadow-lg border-0">
            <h4 class="text-gradient-gold fw-bold mb-4">BÁO CÁO CÔNG VIỆC & KHÁCH HÀNG</h4>
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">TÊN KHÁCH HÀNG</label>
                    <input asp-for="TenKhachHang" class="form-control luxury-input" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">NỘI DUNG CÔNG VIỆC</label>
                    <textarea asp-for="NoiDungCongViec" class="form-control luxury-input" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">SỐ GIỜ THỰC HIỆN</label>
                    <input asp-for="SoGioLam" type="number" class="form-control luxury-input" />
                </div>
                <button type="submit" class="btn btn-luxury w-100 fw-bold py-2">GỬI BÁO CÁO</button>
            </form>
        </div>
    </div>
</div>